---
---

<section id="hero" class="hero-cinematic relative overflow-hidden flex items-center justify-center" style="background-color: var(--clr-cream);">
  <!-- Animated mesh background -->
  <div class="absolute inset-0 hero-mesh"></div>
  <div class="absolute inset-0 hero-vignette"></div>
  <div class="absolute inset-0 noise-bg" style="opacity: 0.85;"></div>

  <!-- HUGE faded "14" decorative -->
  <div class="hero-bg-numeral pointer-events-none select-none" aria-hidden="true">
    <span class="italic-accent">14</span>
  </div>

  <!-- Top-left masthead -->
  <div class="hero-corner hero-corner-tl hero-reveal hero-reveal-1" aria-hidden="true">
    <span class="font-mono-accent">STUDIO·14</span>
    <span class="hero-rule"></span>
    <span class="font-mono-accent">VOL. 14 · ’26</span>
  </div>

  <!-- Top-right chip -->
  <div class="hero-corner hero-corner-tr hero-reveal hero-reveal-1">
    <span class="chip-limited">5 cupos · Abril 2026</span>
  </div>

  <!-- Bottom-left credit line -->
  <div class="hero-corner hero-corner-bl hero-reveal hero-reveal-5" aria-hidden="true">
    <div class="flex items-center gap-3">
      <div class="flex -space-x-2">
        <div class="w-7 h-7 rounded-full border-2" style="background-color: var(--clr-blue); border-color: var(--clr-cream);"></div>
        <div class="w-7 h-7 rounded-full border-2" style="background-color: var(--clr-primary-light); border-color: var(--clr-cream);"></div>
        <div class="w-7 h-7 rounded-full border-2" style="background-color: var(--clr-primary); border-color: var(--clr-cream);"></div>
      </div>
      <p class="text-[10px] md:text-xs text-primary/60 font-mono-accent tracking-widest uppercase">
        Marcas que nos eligen mes a mes
      </p>
    </div>
  </div>

  <!-- Bottom-right edition stamp -->
  <div class="hero-corner hero-corner-br hero-reveal hero-reveal-5" aria-hidden="true">
    <div class="hero-stamp">
      <span class="font-mono-accent text-[8px] tracking-[0.3em]">PRESS</span>
      <span class="italic-accent text-2xl leading-none">N°14</span>
      <span class="font-mono-accent text-[8px] tracking-[0.3em]">2026</span>
    </div>
  </div>

  <!-- Scroll indicator (bottom center) -->
  <div class="hero-scroll-cue hero-reveal hero-reveal-5" aria-hidden="true">
    <span class="font-mono-accent text-[10px] tracking-[0.3em] uppercase text-primary/50">Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>

  <!-- Main content: massive editorial headline -->
  <div class="relative z-10 w-full max-w-[1100px] px-5 md:px-8 text-center py-16 md:py-20">
    <p class="hero-reveal hero-reveal-2 hero-eyebrow font-mono-accent">
      Studio 14 — Agencia boutique chilena
    </p>

    <h1 class="hero-reveal hero-reveal-3 hero-headline">
      <span class="block">Tu marca merece</span>
      <span class="italic-accent block" style="color: var(--clr-primary-light);">estar presente,</span>
      <span class="block">no solo publicar.</span>
    </h1>

    <div class="hero-reveal hero-reveal-4 hero-deck-wrap">
      <span class="hero-rule-h"></span>
      <p class="hero-deck">
        Contenido, paid media y páginas web —<br class="hidden md:block"/>
        para marcas que entienden que verse bien también vende.
      </p>
      <span class="hero-rule-h"></span>
    </div>

    <div class="hero-reveal hero-reveal-4 mt-10 md:mt-12 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
      <a href="#contacto" class="btn-primary text-[0.95rem] !py-4 !px-9 w-full sm:w-auto text-center touch-manipulation">
        Reservar mi cupo &rarr;
      </a>
      <a href="#servicios" class="btn-secondary text-[0.95rem] !py-4 !px-9 w-full sm:w-auto text-center touch-manipulation">
        Ver servicios
      </a>
    </div>
  </div>
</section>

<style>
  /* === Hero cinematic === */
  .hero-cinematic {
    min-height: calc(100svh - 5.5rem);
    padding: 5rem 1rem 6rem;
  }
  @media (min-width: 768px) {
    .hero-cinematic {
      min-height: calc(100svh - 6rem);
      padding: 4rem 2rem;
    }
  }

  /* === Mesh background === */
  .hero-mesh {
    background:
      radial-gradient(ellipse 70% 55% at 18% 22%, rgba(255, 241, 181, 0.95) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 82% 30%, rgba(193, 219, 232, 0.78) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 25% 88%, rgba(193, 219, 232, 0.55) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 80% 85%, rgba(255, 241, 181, 0.65) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(67, 48, 46, 0.05) 0%, transparent 70%),
      linear-gradient(135deg, #FAF6EE 0%, #FFF1B5 60%, #FFF8DC 100%);
    animation: heroMeshMove 18s ease-in-out infinite alternate;
  }

  /* Subtle vignette so corners feel weighted */
  .hero-vignette {
    background:
      radial-gradient(ellipse at center, transparent 55%, rgba(67, 48, 46, 0.07) 100%);
    pointer-events: none;
  }

  /* Massive faded "14" decorative numeral */
  .hero-bg-numeral {
    position: absolute;
    bottom: -12vh;
    right: -3vw;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    line-height: 0.8;
    color: var(--clr-primary);
    opacity: 0.05;
    font-size: clamp(20rem, 50vw, 45rem);
    letter-spacing: -0.05em;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .hero-bg-numeral {
      bottom: -8vh;
      right: -8vw;
      font-size: 22rem;
      opacity: 0.04;
    }
  }

  /* === Corner ornaments === */
  .hero-corner {
    position: absolute;
    z-index: 5;
    color: var(--clr-primary);
  }

  .hero-corner-tl {
    top: 5.5rem;
    left: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  @media (min-width: 768px) {
    .hero-corner-tl {
      top: 1.75rem;
      left: 2.5rem;
    }
  }
  @media (max-width: 640px) {
    .hero-corner-tl { display: none; }
  }

  .hero-corner-tr {
    top: 5.5rem;
    right: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-corner-tr {
      top: 1.75rem;
      right: 2.5rem;
    }
  }
  @media (max-width: 640px) {
    .hero-corner-tr {
      top: auto;
      bottom: 1rem;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
    }
  }

  .hero-corner-bl {
    bottom: 1.75rem;
    left: 2.5rem;
  }
  @media (max-width: 768px) {
    .hero-corner-bl { display: none; }
  }

  .hero-corner-br {
    bottom: 1.75rem;
    right: 2.5rem;
    transform: rotate(-6deg);
  }
  @media (max-width: 768px) {
    .hero-corner-br { display: none; }
  }

  .hero-rule {
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  /* === Edition stamp === */
  .hero-stamp {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 1.5px solid var(--clr-primary);
    background-color: var(--clr-cream);
    color: var(--clr-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    box-shadow: 0 12px 28px -10px rgba(67, 48, 46, 0.3);
  }

  /* === Scroll cue === */
  .hero-scroll-cue {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 5;
  }
  .hero-scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(67, 48, 46, 0.6) 0%, transparent 100%);
    animation: scrollPulse 2.4s ease-in-out infinite;
    transform-origin: top;
  }
  @media (max-width: 768px) {
    .hero-scroll-cue { display: none; }
  }

  /* === Headline === */
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--clr-primary);
    opacity: 0.7;
    margin-bottom: 1.75rem;
    padding: 0.4rem 1rem;
    border-top: 1px solid rgba(67, 48, 46, 0.25);
    border-bottom: 1px solid rgba(67, 48, 46, 0.25);
  }
  @media (min-width: 768px) {
    .hero-eyebrow { margin-bottom: 2.5rem; }
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: clamp(2.85rem, 11vw, 8.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--clr-primary);
    margin-bottom: 2rem;
  }
  .hero-headline .italic-accent {
    font-style: italic;
    font-weight: 400;
  }
  @media (min-width: 768px) {
    .hero-headline {
      margin-bottom: 2.75rem;
      letter-spacing: -0.045em;
    }
  }

  /* === Deck (subtitle with rules) === */
  .hero-deck-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    max-width: 44rem;
    margin: 0 auto;
  }
  .hero-rule-h {
    flex: 1;
    height: 1px;
    background: rgba(67, 48, 46, 0.25);
    max-width: 4rem;
  }
  .hero-deck {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--clr-primary);
    opacity: 0.78;
    font-style: italic;
    font-family: var(--font-heading);
    flex-shrink: 0;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-deck {
      font-size: 1.15rem;
    }
  }
  @media (max-width: 640px) {
    .hero-rule-h { max-width: 2rem; }
    .hero-deck { font-size: 0.85rem; }
  }

  /* === Animations === */
  @keyframes heroMeshMove {
    0% {
      background-position: 0% 0%, 100% 0%, 0% 100%, 100% 100%, 50% 50%, 0% 0%;
    }
    50% {
      background-position: 8% 6%, 92% 8%, 6% 94%, 94% 92%, 52% 48%, 0% 0%;
    }
    100% {
      background-position: 4% 12%, 96% 4%, 12% 96%, 88% 96%, 48% 52%, 0% 0%;
    }
  }

  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.8; }
    50% { transform: scaleY(0.6); opacity: 0.3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-mesh,
    .hero-scroll-line { animation: none !important; }
  }
</style>
