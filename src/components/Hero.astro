---
---

<section id="hero" class="hero-cinematic relative overflow-hidden flex items-center justify-center" style="background-color: var(--clr-cream);">
  <!-- Animated mesh background -->
  <div class="absolute inset-0 hero-mesh"></div>
  <div class="absolute inset-0 hero-vignette"></div>
  <div class="absolute inset-0 noise-bg" style="opacity: 0.85;"></div>

  <!-- HUGE faded "14" decorative -->
  <div class="hero-bg-numeral pointer-events-none select-none" aria-hidden="true">
    <span class="italic-accent">14</span>
  </div>

  <!-- Top-left masthead -->
  <div class="hero-corner hero-corner-tl hero-reveal hero-reveal-1" aria-hidden="true">
    <span class="font-mono-accent">STUDIO·14</span>
    <span class="hero-rule"></span>
    <span class="font-mono-accent">VOL. 14 · ’26</span>
  </div>

  <!-- Main content: massive editorial headline -->
  <div class="relative z-10 w-full max-w-[1100px] px-5 md:px-8 text-center py-8 md:py-10">
    <p class="hero-reveal hero-reveal-2 hero-eyebrow font-mono-accent">
      Studio 14 — Agencia de marketing
    </p>

    <h1 class="hero-reveal hero-reveal-3 hero-headline">
      <span class="block">Estar siempre presente,</span>
      <span class="italic-accent block" style="color: var(--clr-primary-light);">sin estar siempre pendiente.</span>
    </h1>

    <div class="hero-reveal hero-reveal-4 hero-deck-wrap">
      <span class="hero-rule-h"></span>
      <p class="hero-deck">
        Mantenemos tu Instagram, tus anuncios y tu web activos cada mes —<br class="hidden md:block"/>
        mientras tú haces lo tuyo.
      </p>
      <span class="hero-rule-h"></span>
    </div>

    <div class="hero-reveal hero-reveal-4 mt-10 md:mt-12 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
      <a href="#contacto" class="btn-primary text-[0.95rem] !py-4 !px-9 w-full sm:w-auto text-center touch-manipulation">
        Hablemos &rarr;
      </a>
      <a href="#servicios" class="btn-secondary text-[0.95rem] !py-4 !px-9 w-full sm:w-auto text-center touch-manipulation">
        Ver servicios
      </a>
    </div>
  </div>
</section>

<style>
  /* === Hero cinematic === */
  .hero-cinematic {
    min-height: auto;
    padding: 4rem 1rem 3.5rem;
  }
  @media (min-width: 768px) {
    .hero-cinematic {
      min-height: 78svh;
      padding: 3rem 2rem;
    }
  }

  /* === Mesh background === */
  .hero-mesh {
    background:
      radial-gradient(ellipse 60% 50% at 15% 20%, rgba(255, 241, 181, 0.85) 0%, transparent 60%),
      radial-gradient(ellipse 75% 60% at 85% 25%, rgba(193, 219, 232, 0.95) 0%, transparent 60%),
      radial-gradient(ellipse 80% 65% at 20% 90%, rgba(193, 219, 232, 0.85) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 80% 85%, rgba(255, 241, 181, 0.55) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(67, 48, 46, 0.05) 0%, transparent 70%),
      linear-gradient(135deg, #FAF6EE 0%, #E4F0F6 50%, #FFF8DC 100%);
    animation: heroMeshMove 18s ease-in-out infinite alternate;
  }

  /* Subtle vignette so corners feel weighted */
  .hero-vignette {
    background:
      radial-gradient(ellipse at center, transparent 55%, rgba(67, 48, 46, 0.07) 100%);
    pointer-events: none;
  }

  /* Massive faded "14" decorative numeral */
  .hero-bg-numeral {
    position: absolute;
    bottom: -12vh;
    right: -3vw;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    line-height: 0.8;
    color: var(--clr-primary);
    opacity: 0.05;
    font-size: clamp(20rem, 50vw, 45rem);
    letter-spacing: -0.05em;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .hero-bg-numeral {
      bottom: -8vh;
      right: -8vw;
      font-size: 22rem;
      opacity: 0.04;
    }
  }

  /* === Corner ornaments === */
  .hero-corner {
    position: absolute;
    z-index: 5;
    color: var(--clr-primary);
  }

  .hero-corner-tl {
    top: 5.5rem;
    left: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  @media (min-width: 768px) {
    .hero-corner-tl {
      top: 1.75rem;
      left: 2.5rem;
    }
  }
  @media (max-width: 640px) {
    .hero-corner-tl { display: none; }
  }

  .hero-rule {
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  /* === Headline === */
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--clr-primary);
    opacity: 0.7;
    margin-bottom: 1.75rem;
    padding: 0.4rem 1rem;
    border-top: 1px solid rgba(67, 48, 46, 0.25);
    border-bottom: 1px solid rgba(67, 48, 46, 0.25);
  }
  @media (min-width: 768px) {
    .hero-eyebrow { margin-bottom: 2.5rem; }
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: clamp(2.85rem, 11vw, 8.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--clr-primary);
    margin-bottom: 2rem;
  }
  .hero-headline .italic-accent {
    font-style: italic;
    font-weight: 400;
  }
  @media (min-width: 768px) {
    .hero-headline {
      margin-bottom: 2.75rem;
      letter-spacing: -0.045em;
    }
  }

  /* === Deck (subtitle with rules) === */
  .hero-deck-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    max-width: 44rem;
    margin: 0 auto;
  }
  .hero-rule-h {
    flex: 1;
    height: 1px;
    background: rgba(67, 48, 46, 0.25);
    max-width: 4rem;
  }
  .hero-deck {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--clr-primary);
    opacity: 0.78;
    font-style: italic;
    font-family: var(--font-heading);
    flex-shrink: 0;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-deck {
      font-size: 1.15rem;
    }
  }
  @media (max-width: 640px) {
    .hero-rule-h { max-width: 2rem; }
    .hero-deck { font-size: 0.85rem; }
  }

  /* === Animations === */
  @keyframes heroMeshMove {
    0% {
      background-position: 0% 0%, 100% 0%, 0% 100%, 100% 100%, 50% 50%, 0% 0%;
    }
    50% {
      background-position: 8% 6%, 92% 8%, 6% 94%, 94% 92%, 52% 48%, 0% 0%;
    }
    100% {
      background-position: 4% 12%, 96% 4%, 12% 96%, 88% 96%, 48% 52%, 0% 0%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-mesh { animation: none !important; }
  }
</style>
