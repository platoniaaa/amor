---
const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: '¿Por qué Studio 14?', href: '#por-que-studio14' },
  { label: 'Sobre nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const year = new Date().getFullYear();
---

<footer class="relative pt-16 md:pt-24 pb-10 overflow-hidden" style="background-color: var(--clr-primary);">
  <div class="absolute inset-0 noise-bg opacity-60"></div>

  <!-- Huge wordmark background -->
  <div class="absolute -bottom-16 -left-10 pointer-events-none select-none opacity-[0.06]">
    <span class="italic-accent text-[18rem] md:text-[30rem] leading-none font-medium" style="color: var(--clr-cream);">Studio14</span>
  </div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 pb-12 md:pb-16 border-b border-cream/15">
      <!-- Logo & description -->
      <div class="md:col-span-1">
        <div class="flex items-baseline gap-0.5 mb-6">
          <span class="italic-accent text-3xl font-medium" style="color: var(--clr-cream);">Studio</span>
          <span class="font-mono-accent text-2xl font-bold ml-0.5" style="color: var(--clr-cream);">14</span>
        </div>
        <p class="text-cream/60 text-sm leading-relaxed max-w-xs mb-6">
          Agencia creativa boutique. Contenido, campañas Meta Ads y páginas web para marcas que cuidan su presencia.
        </p>
        <span class="chip-limited" style="background-color: rgba(255, 241, 181, 0.12); border-color: rgba(255, 241, 181, 0.25); color: var(--clr-cream);">
          5 cupos al mes
        </span>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-mono-accent text-cream/50 mb-6 text-[11px] tracking-[0.25em] uppercase">Navegación</h4>
        <ul class="space-y-3">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-cream/75 hover:text-cream transition-colors text-sm" style="font-family: var(--font-heading);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-mono-accent text-cream/50 mb-6 text-[11px] tracking-[0.25em] uppercase">Contacto</h4>
        <ul class="space-y-3 text-sm text-cream/75">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-blue);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            hola@studio14.cl
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-blue);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            +56 9 7600 9119
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-blue);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Santiago, Chile
          </li>
        </ul>

        <!-- Social icons -->
        <div class="flex gap-3 mt-7">
          <a href="#" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300 hover:scale-105" style="background-color: rgba(255, 241, 181, 0.1); border: 1px solid rgba(255, 241, 181, 0.2);" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-cream);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300 hover:scale-105" style="background-color: rgba(255, 241, 181, 0.1); border: 1px solid rgba(255, 241, 181, 0.2);" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-cream);" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005.8 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.84-.1z"/></svg>
          </a>
          <a href="https://wa.me/56976009119" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300 hover:scale-105" style="background-color: rgba(255, 241, 181, 0.1); border: 1px solid rgba(255, 241, 181, 0.2);" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: var(--clr-cream);" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-cream/40 text-xs font-mono-accent tracking-wide">
        &copy; {year} Studio 14. Todos los derechos reservados.
      </p>
      <p class="text-cream/40 text-xs italic-accent">
        Curado con cuidado en Santiago.
      </p>
    </div>
  </div>
</footer>
