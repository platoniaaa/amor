---
const services = [
  {
    number: '01',
    badge: 'Contenido',
    title: 'Creación de contenido',
    description: 'Una jornada de producción al mes contigo, y de ahí sacamos todo lo que vas a publicar en tus redes.',
    includes: [
      {
        title: 'Producción mensual de contenido',
        detail: 'Una jornada al mes en tu local o donde tu marca esté pasando.'
      },
      {
        title: 'Editamos y publicamos por ti',
        detail: 'Reels, historias y posts subidos directo a tus redes.'
      },
      {
        title: 'Reciclamos el contenido',
        detail: 'De una jornada sacamos piezas para todo el mes.'
      },
      {
        title: 'Manual de marca incluido',
        detail: 'Tus colores, tipografías y estilo visual en un documento.'
      }
    ],
    accentVar: '--clr-cream'
  },
  {
    number: '02',
    badge: 'Performance',
    title: 'Paid Media',
    description: 'Publicidad pagada en Instagram y Facebook — y solo ahí. Estrategia, contenido, presupuesto y reporte de cierre.',
    includes: [
      {
        title: 'Segmentación de audiencia',
        detail: 'Tus anuncios solo los ve gente que podría ser cliente.'
      },
      {
        title: 'Diseño del anuncio',
        detail: 'Imágenes, videos y textos pensados para que actúen.'
      },
      {
        title: 'Gestión del presupuesto',
        detail: 'Definimos cuánto invertir, cuándo y en qué anuncio.'
      },
      {
        title: 'Reporte básico al cierre',
        detail: 'Resumen con resultados al finalizar cada campaña.'
      }
    ],
    accentVar: '--clr-blue'
  },
  {
    number: '03',
    badge: 'Presencia',
    title: 'Páginas web',
    description: 'Nos juntamos, escuchamos qué necesitas y diseñamos tu página web a medida.',
    includes: [
      {
        title: 'Reunión inicial',
        detail: 'Conversamos para conocer tu marca y tus objetivos.'
      },
      {
        title: 'Diseño a tu medida',
        detail: 'Desde cero, no una plantilla copiada.'
      },
      {
        title: 'Optimizada para celular y Google',
        detail: 'Se ve bien en móvil y aparece cuando te buscan.'
      },
      {
        title: 'Dominio incluido el primer año',
        detail: 'Tu dirección web (ej: tumarca.cl) la primera anualidad.'
      }
    ],
    accentVar: '--clr-primary-light'
  }
];
---

<section id="servicios" class="relative py-16 md:py-32 overflow-hidden" style="background-color: var(--clr-bone);">
  <div class="absolute inset-0 noise-bg opacity-50"></div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 md:mb-20 fade-up">
      <span class="eyebrow mb-6 inline-block">Lo que hacemos</span>
      <h2 class="section-title mt-4">Tres pilares, <span class="italic-accent" style="color: var(--clr-primary-light);">una sola mirada</span></h2>
      <p class="section-subtitle">
        No vendemos por Instagram — construimos presencia. Servicios pensados para marcas que quieren verse bien sin tener que pensarlo cada semana.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6">
      {services.map((service, i) => (
        <div
          class="fade-up group relative rounded-3xl p-7 md:p-10 border border-primary/10 transition-all duration-500 hover:-translate-y-1 hover:border-primary/25 shadow-editorial hover:shadow-editorial-lg flex flex-col"
          style={`transition-delay: ${i * 120}ms; background-color: var(--clr-white);`}
        >
          <!-- Number + badge -->
          <div class="flex items-center justify-between mb-6">
            <span class="font-mono-accent text-xs text-text-muted tracking-widest">STUDIO · {service.number}</span>
            <span class="text-[10px] font-mono-accent uppercase tracking-[0.2em] px-3 py-1 rounded-full border border-primary/20 text-primary" style={`background-color: var(${service.accentVar});`}>
              {service.badge}
            </span>
          </div>

          <h3 class="text-2xl md:text-3xl font-medium text-primary mb-4 leading-tight" style="font-family: var(--font-heading);">
            {service.title}
          </h3>

          <p class="text-text-muted text-[0.95rem] leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- Includes -->
          <div class="space-y-4 mb-8">
            {service.includes.map(item => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-primary/60 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <div class="flex-1">
                  <p class="text-primary font-medium text-sm leading-snug" style="font-family: var(--font-heading);">{item.title}</p>
                  <p class="text-text-muted text-[0.82rem] leading-relaxed mt-1">{item.detail}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Accent bar at bottom -->
          <div class="h-1 rounded-full -mx-2 mt-auto" style={`background-color: var(${service.accentVar});`}></div>
        </div>
      ))}
    </div>

    <!-- Combined note -->
    <div class="fade-up mt-10 md:mt-16 text-center">
      <p class="italic-accent text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
        &ldquo;Los tres servicios se combinan o se contratan por separado. Lo que no hacemos es copiar y pegar estrategias.&rdquo;
      </p>
    </div>
  </div>
</section>
