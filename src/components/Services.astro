---
const services = [
  {
    number: '01',
    badge: 'Performance',
    title: 'Campañas y anuncios pagados',
    description: 'Publicidad pagada en Instagram y Facebook. Estrategia, contenido, presupuesto y reporte de cierre.',
    includes: [
      {
        title: 'Segmentación de audiencia',
        detail: 'Tus anuncios solo los ve gente que podría ser cliente.'
      },
      {
        title: 'Diseño del anuncio',
        detail: 'Imágenes, videos y textos pensados para que actúen.'
      },
      {
        title: 'Gestión del presupuesto',
        detail: 'Definimos cuánto invertir, cuándo y en qué anuncio.'
      },
      {
        title: 'Reporte básico al cierre',
        detail: 'Resumen con resultados al finalizar cada campaña.'
      }
    ],
    accentVar: '--clr-blue'
  },
  {
    number: '02',
    badge: 'Contenido',
    title: 'Creación de contenido mensual',
    description: 'Una jornada de producción al mes contigo: grabamos, fotografiamos y editamos todo lo que vas a publicar en tus redes.',
    includes: [
      {
        title: 'Una jornada al mes',
        detail: 'Vamos una vez al mes a grabar y fotografiar a tu local, evento o donde tu marca esté pasando.'
      },
      {
        title: 'Edición de fotos y videos',
        detail: 'Reels, historias y publicaciones del feed editados y listos.'
      },
      {
        title: 'Publicamos en tus redes',
        detail: 'Subimos directo a tu Instagram. Tú no tienes que hacer nada.'
      },
      {
        title: 'Manual de marca incluido',
        detail: 'Tus colores, tipografías y estilo visual en un documento.'
      }
    ],
    accentVar: '--clr-cream'
  },
  {
    number: '03',
    badge: 'Presencia',
    title: 'Páginas web',
    description: 'Nos juntamos, escuchamos qué necesitas y diseñamos tu página web a medida.',
    includes: [
      {
        title: 'Reunión inicial',
        detail: 'Conversamos para conocer tu marca y tus objetivos.'
      },
      {
        title: 'Diseño a tu medida',
        detail: 'Desde cero, no una plantilla copiada.'
      },
      {
        title: 'Optimizada para celular y Google',
        detail: 'Se ve bien en móvil y aparece cuando te buscan.'
      },
      {
        title: 'Dominio incluido los primeros 2 años',
        detail: 'Tu dirección web (ej: tumarca.cl) cubierta las dos primeras anualidades.'
      }
    ],
    accentVar: '--clr-primary-light',
    badgeTextVar: '--clr-cream'
  }
];
---

<section id="servicios" class="relative py-12 md:py-20 overflow-hidden" style="background-color: var(--clr-bone);">
  <div class="absolute inset-0 noise-bg opacity-50"></div>

  <!-- Decorative blue blurs -->
  <div class="absolute top-1/4 -right-32 w-96 h-96 rounded-full blur-3xl opacity-50 pointer-events-none" style="background-color: var(--clr-blue);"></div>
  <div class="absolute bottom-0 -left-20 w-72 h-72 rounded-full blur-3xl opacity-40 pointer-events-none" style="background-color: var(--clr-blue-light);"></div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-10 md:mb-14 fade-up">
      <span class="eyebrow mb-6 inline-block">Lo que hacemos</span>
      <h2 class="section-title mt-4">Tres servicios, <span class="italic-accent" style="color: var(--clr-primary-light);">una sola mirada</span></h2>
      <p class="section-subtitle">
        Cada servicio se contrata <strong class="text-primary font-semibold">de forma individual o combinado</strong>, según lo que necesite tu marca. Si quieres todo bajo un mismo plan, mira la sección de planes más abajo.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6">
      {services.map((service, i) => (
        <div
          class="fade-up group relative rounded-3xl p-7 md:p-10 border border-primary/10 transition-all duration-500 hover:-translate-y-1 hover:border-primary/25 shadow-editorial hover:shadow-editorial-lg flex flex-col"
          style={`transition-delay: ${i * 120}ms; background-color: var(--clr-white);`}
        >
          <!-- Number + badge -->
          <div class="flex items-center justify-between mb-6">
            <span class="font-mono-accent text-xs text-text-muted tracking-widest">STUDIO · {service.number}</span>
            <span class="text-[10px] font-mono-accent uppercase tracking-[0.2em] px-3 py-1 rounded-full border border-primary/20" style={`background-color: var(${service.accentVar}); color: var(${service.badgeTextVar || '--clr-primary'});`}>
              {service.badge}
            </span>
          </div>

          <h3 class="text-2xl md:text-3xl font-medium text-primary mb-4 leading-tight" style="font-family: var(--font-heading);">
            {service.title}
          </h3>

          <p class="text-text-muted text-[0.95rem] leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- Includes -->
          <div class="space-y-4 mb-6">
            {service.includes.map(item => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-primary/60 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <div class="flex-1">
                  <p class="text-primary font-medium text-sm leading-snug" style="font-family: var(--font-heading);">{item.title}</p>
                  <p class="text-text-muted text-[0.82rem] leading-relaxed mt-1">{item.detail}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <a href="#contacto" class="service-cta mt-auto">
            Lo quiero &rarr;
          </a>

          <!-- Accent bar at bottom -->
          <div class="h-1 rounded-full -mx-2 mt-5" style={`background-color: var(${service.accentVar});`}></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .service-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background-color: transparent;
    color: var(--clr-primary);
    font-family: var(--font-sans);
    font-weight: 600;
    border: 1px solid rgba(67, 48, 46, 0.3);
    border-radius: 999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    font-size: 0.88rem;
    letter-spacing: 0.01em;
    touch-action: manipulation;
  }
  .service-cta:hover {
    background-color: var(--clr-primary);
    color: var(--clr-cream);
    border-color: var(--clr-primary);
    transform: translateY(-1px);
    box-shadow: 0 8px 18px -6px rgba(67, 48, 46, 0.3);
  }
</style>
