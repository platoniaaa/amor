---
const differentiators = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Boutique, no masivo',
    description: 'Trabajamos con solo 5 marcas al mes. Eso significa atención real, no carpetas olvidadas en un Drive.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: 'Presencia, no venta forzada',
    description: 'Si tu negocio no vive de vender por Instagram, tampoco deberías publicar como si lo hiciera. Construimos imagen, no spam.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: 'Una sola mirada',
    description: 'Contenido, pauta y web diseñados por el mismo equipo. Sin traducciones entre freelancers ni estilos disociados.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: 'Estética cuidada',
    description: 'Cada pieza pasa por una dirección visual. Si no sube el nivel de tu marca, no se publica.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v4H3z"/><path d="M3 10h18v4H3z"/><path d="M3 17h18v4H3z"/></svg>`,
    title: 'Reportes sin humo',
    description: 'Cada mes recibes un reporte claro: qué hicimos, qué funcionó y qué ajustamos. Sin jerga, sin adorno.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Cercanía real',
    description: 'Un contacto directo y reuniones con personas que conocen tu marca por su nombre.'
  }
];

const steps = [
  {
    number: '01',
    title: 'Conversamos',
    description: 'Agendamos una llamada breve. Entendemos tu marca, tu tono, lo que te gusta y lo que no quieres ver publicado jamás.'
  },
  {
    number: '02',
    title: 'Diseñamos',
    description: 'Proponemos una dirección visual, un plan de contenido y — si aplica — la estrategia de pauta y la estructura del sitio.'
  },
  {
    number: '03',
    title: 'Producimos',
    description: 'Agendamos la sesión fotográfica, diseñamos, grabamos, editamos y construimos. Tú apruebas antes de que algo salga.'
  },
  {
    number: '04',
    title: 'Sostenemos',
    description: 'Mantenemos tu presencia viva mes a mes, ajustamos según resultados y te dejamos tranquila/o sabiendo que todo se ve bien.'
  }
];
---

<section id="por-que-studio14" class="relative py-16 md:py-32 overflow-hidden" style="background-color: var(--clr-white);">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-14 md:mb-20 fade-up">
      <span class="eyebrow mb-6 inline-block">¿Por qué Studio 14?</span>
      <h2 class="section-title mt-4">Una agencia que <span class="italic-accent" style="color: var(--clr-primary-light);">elige pocos clientes</span></h2>
      <p class="section-subtitle">
        Porque cuidar una marca toma tiempo. Y el tiempo no se escala.
      </p>
    </div>

    <!-- Differentiators grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 mb-20 md:mb-28">
      {differentiators.map((item, i) => (
        <div
          class="fade-up group relative rounded-2xl p-6 md:p-8 border border-primary/8 transition-all duration-500 hover:border-primary/20 hover:-translate-y-1"
          style={`transition-delay: ${i * 80}ms; background-color: var(--clr-bone);`}
        >
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-primary mb-5 border border-primary/15" style="background-color: var(--clr-cream);">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-lg md:text-xl font-medium text-primary mb-2" style="font-family: var(--font-heading);">{item.title}</h3>
          <p class="text-text-muted leading-relaxed text-[0.95rem]">{item.description}</p>
        </div>
      ))}
    </div>

    <!-- Process timeline -->
    <div class="fade-up">
      <div class="text-center mb-12 md:mb-16">
        <span class="eyebrow mb-4 inline-block">El proceso</span>
        <h3 class="text-3xl md:text-5xl font-medium text-primary mt-4" style="font-family: var(--font-heading);">
          Cómo <span class="italic-accent" style="color: var(--clr-primary-light);">trabajamos</span>
        </h3>
      </div>

      <!-- Desktop: horizontal timeline -->
      <div class="hidden md:grid grid-cols-4 gap-6 relative">
        <!-- Connecting line -->
        <div class="absolute top-10 left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, rgba(67, 48, 46, 0.2), rgba(67, 48, 46, 0.35), rgba(67, 48, 46, 0.2));"></div>

        {steps.map((step, i) => (
          <div class="fade-up text-center relative" style={`transition-delay: ${i * 150}ms`}>
            <div class="relative z-10 mx-auto w-20 h-20 rounded-full flex items-center justify-center mb-6 shadow-editorial" style="background-color: var(--clr-cream); border: 2px solid var(--clr-primary);">
              <span class="font-mono-accent text-lg font-bold" style="color: var(--clr-primary);">{step.number}</span>
            </div>
            <h4 class="font-medium text-primary text-xl mb-2" style="font-family: var(--font-heading);">{step.title}</h4>
            <p class="text-text-muted text-sm leading-relaxed px-2">{step.description}</p>
          </div>
        ))}
      </div>

      <!-- Mobile: vertical timeline -->
      <div class="md:hidden space-y-8 relative pl-14">
        <div class="absolute top-2 bottom-2 left-6 w-px" style="background: linear-gradient(to bottom, rgba(67, 48, 46, 0.2), rgba(67, 48, 46, 0.35), rgba(67, 48, 46, 0.2));"></div>

        {steps.map((step, i) => (
          <div class="fade-up relative" style={`transition-delay: ${i * 150}ms`}>
            <div class="absolute -left-14 top-0 w-12 h-12 rounded-full flex items-center justify-center shadow-editorial" style="background-color: var(--clr-cream); border: 2px solid var(--clr-primary);">
              <span class="font-mono-accent text-xs font-bold" style="color: var(--clr-primary);">{step.number}</span>
            </div>
            <h4 class="font-medium text-primary text-xl mb-1" style="font-family: var(--font-heading);">{step.title}</h4>
            <p class="text-text-muted text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
