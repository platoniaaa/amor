---
const services = [
  {
    number: '01',
    badge: 'Contenido',
    title: 'Creación de contenido',
    description: 'Fotografía, video, edición y diseño gráfico. Contenido pensado para que tus redes se vean impecables mes a mes — sin improvisaciones ni stock genérico.',
    includes: [
      {
        title: 'Sesiones fotográficas mensuales',
        detail: 'Vamos a tu local o estudio una vez al mes a tomar las fotos que vas a usar todo el mes en tus redes.'
      },
      {
        title: 'Reels y videos cortos editados',
        detail: 'Esos videos verticales que ves en Instagram y TikTok — los grabamos, los editamos y los dejamos listos para publicar.'
      },
      {
        title: 'Diseño gráfico para feed e historias',
        detail: 'Las publicaciones cuadradas que aparecen en tu perfil y las historias que duran 24 horas, todas en la misma línea visual.'
      },
      {
        title: 'Línea visual consistente',
        detail: 'Todo lo que sale de tu marca se ve "de la misma familia": colores, tipografías y estilo de fotos siempre coherentes.'
      }
    ],
    accentVar: '--clr-cream'
  },
  {
    number: '02',
    badge: 'Performance',
    title: 'Paid Media',
    description: 'Estrategia, segmentación y gestión de publicidad pagada en Instagram y Facebook. Convertimos tu presupuesto en resultados medibles, no en likes vacíos.',
    includes: [
      {
        title: 'Plan de inversión mensual',
        detail: 'Definimos cuánto invertir, cuándo y en qué tipo de anuncio según los objetivos del mes (más seguidores, más mensajes, más visitas a tu web, etc.).'
      },
      {
        title: 'Anuncios mostrados solo a gente relevante',
        detail: 'Configuramos los anuncios para que los vean únicamente las personas que podrían convertirse en tus clientes — por edad, ubicación, intereses y comportamiento.'
      },
      {
        title: 'Diseño de los anuncios',
        detail: 'Creamos las imágenes, videos y textos que la gente va a ver, pensados para que actúen (te escriban, visiten tu web o sigan tu cuenta), no solo miren.'
      },
      {
        title: 'Reporte mensual básico',
        detail: 'Te enviamos un resumen claro: cuánta gente vio tus anuncios, cuántos te contactaron y qué vamos a ajustar el próximo mes.'
      }
    ],
    accentVar: '--clr-blue'
  },
  {
    number: '03',
    badge: 'Presencia',
    title: 'Páginas web',
    description: 'Diseño y desarrollo de sitios web que comunican tu marca con estilo. Rápidos, responsivos y pensados para que tu cliente encuentre lo que busca sin fricciones.',
    includes: [
      {
        title: 'Diseño a medida, no plantillas',
        detail: 'Tu sitio se diseña desde cero pensando en tu marca — no descargamos un template genérico que se vea igual al de otros 100 negocios.'
      },
      {
        title: 'Se ve bien en celular y aparece en Google',
        detail: 'Optimizada para que se vea perfecta desde el celular (donde la mira la mayoría) y configurada con lo básico para que Google la encuentre cuando alguien te busca.'
      },
      {
        title: 'Conectada con tus redes y WhatsApp',
        detail: 'Botones directos a Instagram, WhatsApp o el medio que uses, para que tu visita pase de la web al contacto en un solo clic.'
      },
      {
        title: 'Dominio y hosting incluidos el primer año',
        detail: 'Nos encargamos de comprar tu dirección web (ej. tumarca.cl) y del servidor donde vive el sitio durante el primer año, sin costos extra.'
      }
    ],
    accentVar: '--clr-primary-light'
  }
];
---

<section id="servicios" class="relative py-16 md:py-32 overflow-hidden" style="background-color: var(--clr-bone);">
  <div class="absolute inset-0 noise-bg opacity-50"></div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 md:mb-20 fade-up">
      <span class="eyebrow mb-6 inline-block">Lo que hacemos</span>
      <h2 class="section-title mt-4">Tres pilares, <span class="italic-accent" style="color: var(--clr-primary-light);">una sola mirada</span></h2>
      <p class="section-subtitle">
        No vendemos por Instagram — construimos presencia. Servicios pensados para marcas que quieren verse bien sin tener que pensarlo cada semana.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6">
      {services.map((service, i) => (
        <div
          class="fade-up group relative rounded-3xl p-7 md:p-10 border border-primary/10 transition-all duration-500 hover:-translate-y-1 hover:border-primary/25 shadow-editorial hover:shadow-editorial-lg flex flex-col"
          style={`transition-delay: ${i * 120}ms; background-color: var(--clr-white);`}
        >
          <!-- Number + badge -->
          <div class="flex items-center justify-between mb-6">
            <span class="font-mono-accent text-xs text-text-muted tracking-widest">STUDIO · {service.number}</span>
            <span class="text-[10px] font-mono-accent uppercase tracking-[0.2em] px-3 py-1 rounded-full border border-primary/20 text-primary" style={`background-color: var(${service.accentVar});`}>
              {service.badge}
            </span>
          </div>

          <h3 class="text-2xl md:text-3xl font-medium text-primary mb-4 leading-tight" style="font-family: var(--font-heading);">
            {service.title}
          </h3>

          <p class="text-text-muted text-[0.95rem] leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- Includes -->
          <div class="space-y-4 mb-8 mt-auto">
            {service.includes.map(item => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-primary/60 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <div class="flex-1">
                  <p class="text-primary font-medium text-sm leading-snug" style="font-family: var(--font-heading);">{item.title}</p>
                  <p class="text-text-muted text-[0.82rem] leading-relaxed mt-1">{item.detail}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Accent bar at bottom -->
          <div class="h-1 rounded-full -mx-2" style={`background-color: var(${service.accentVar});`}></div>
        </div>
      ))}
    </div>

    <!-- Combined note -->
    <div class="fade-up mt-10 md:mt-16 text-center">
      <p class="italic-accent text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
        &ldquo;Los tres servicios se combinan o se contratan por separado. Lo que no hacemos es copiar y pegar estrategias.&rdquo;
      </p>
    </div>
  </div>
</section>
